body{
font-family: Arial;
background:#f2f2f2;
text-align:center;
}

h1{
background:#2c7be5;
color:white;
padding:20px;
}

form{
background:white;
width:300px;
margin:20px auto;
padding:20px;
border-radius:10px;
box-shadow:0px 0px 10px gray;
}

input{
width:90%;
padding:10px;
margin:5px;
}

button{
background:#2c7be5;
color:white;
border:none;
padding:10px;
width:100%;
cursor:pointer;
}

button:hover{
background:#1a5ed8;
}
